const firestoreProjectID = "YOUR_PROJECT_ID"; // Paste your project ID here

function syncData() {
  // 1. First, clear the old data in the database
  clearDatabase();
  
  // 2. Then, push the new data from the sheet
  pushToFirestore();
}

function pushToFirestore() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const registerNumber = row[1]?.toString().trim(); // Register Number column
    
    if (!registerNumber || registerNumber === "") continue; // Skip empty rows

    const record = {};
    headers.forEach((header, index) => {
      // Replace spaces with underscores to match Flutter code
      let formattedHeader = header.toString().replace(/\s+/g, '_'); 
      record[formattedHeader] = row[index];
    });

    // Push to Firestore via REST API
    const url = `https://firestore.googleapis.com/v1/projects/${firestoreProjectID}/databases/(default)/documents/results/${registerNumber}`;
    const options = {
      method: "patch", 
      contentType: "application/json",
      payload: JSON.stringify({ fields: createFirestoreFields(record) })
    };
    UrlFetchApp.fetch(url, options);
  }
}

function clearDatabase() {
  // Fetch all current documents
  const getUrl = `https://firestore.googleapis.com/v1/projects/${firestoreProjectID}/databases/(default)/documents/results`;
  const response = UrlFetchApp.fetch(getUrl, { muteHttpExceptions: true });
  const json = JSON.parse(response.getContentText());
  
  if (json.documents) {
    // Delete them one by one
    json.documents.forEach(doc => {
      UrlFetchApp.fetch(`https://firestore.googleapis.com/v1/${doc.name}`, { 
        method: "delete",
        muteHttpExceptions: true
      });
    });
  }
}

function createFirestoreFields(obj) {
  const fields = {};
  for (const key in obj) {
    fields[key] = { stringValue: obj[key] != null ? obj[key].toString() : "" };
  }
  return fields;
}
